# 为所有图片设置一年缓存
/images/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/images/*.png
  Cache-Control: public, max-age=31536000, immutable

/images/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

# 为视频设置缓存（但视频文件大，建议压缩）
/images/*.mp4
  Cache-Control: public, max-age=31536000, immutable